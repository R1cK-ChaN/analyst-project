# Analyst project local environment
# Copy to `.env` and fill values for this self-contained project.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANALYST_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
ANALYST_TELEGRAM_OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
ANALYST_IMAGE_GEN_MODEL=doubao-seedream-5-0-260128
ANALYST_IMAGE_GEN_SIZE=2048x2048
ANALYST_IMAGE_GEN_RESPONSE_FORMAT=url
ANALYST_IMAGE_GEN_WATERMARK=false
ANALYST_SELFIE_MEDIA_ROOT=.analyst/media/persona
ANALYST_SELFIE_BOOTSTRAP_COUNT=4
ANALYST_VIDEO_GEN_PROVIDER=
VOLCENGINE_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ANALYST_LIVE_PHOTO_MODEL=doubao-seedance-1-0-pro-fast-251015
# Optional for future Apple/iMessage delivery on macOS.
ANALYST_MAKELIVE_BINARY=makelive
FRED_API_KEY=

# Telegram bot token from @BotFather
ANALYST_TELEGRAM_TOKEN=your-telegram-bot-token-here

# Interactive Brokers Client Portal Gateway
ANALYST_IBKR_GATEWAY_URL=https://localhost:5000/v1/api
ANALYST_IBKR_ACCOUNT_ID=

# Longbridge (长桥) OpenAPI — https://open.longportapp.com
ANALYST_LONGBRIDGE_APP_KEY=
ANALYST_LONGBRIDGE_APP_SECRET=
ANALYST_LONGBRIDGE_ACCESS_TOKEN=

# Tiger Brokers (老虎证券) Open Platform — https://quant.itigerup.com
# Requires: pip install cryptography (for RSA signing)
ANALYST_TIGER_ID=
ANALYST_TIGER_PRIVATE_KEY=  # PEM file path or inline PEM content
ANALYST_TIGER_ACCOUNT=
