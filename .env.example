# Analyst project local environment
# Copy to `.env` and fill values for this self-contained project.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANALYST_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
ANALYST_TELEGRAM_OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Optional alternate LLM backend. Leave ANALYST_LLM_PLATFORM unset to keep the
# current OpenRouter behavior. Use `anthropic` for direct Anthropic API keys or
# `claude_code` for the local Claude Code CLI + OAuth token flow.
ANALYST_LLM_PLATFORM=
CLAUDE_CODE_OAUTH_TOKEN=
ANALYST_CLAUDE_CODE_MODEL=sonnet
CLAUDE_CODE_CLI_PATH=claude
ANALYST_CLAUDE_CODE_TIMEOUT_SECONDS=180
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANALYST_ANTHROPIC_MODEL=claude-sonnet-4-20250514

ANALYST_IMAGE_GEN_MODEL=doubao-seedream-5-0-260128
ANALYST_IMAGE_GEN_SIZE=2048x2048
ANALYST_IMAGE_GEN_RESPONSE_FORMAT=url
ANALYST_IMAGE_GEN_WATERMARK=false
ANALYST_SELFIE_MEDIA_ROOT=.analyst/media/persona
ANALYST_SELFIE_BOOTSTRAP_COUNT=4
ANALYST_VIDEO_GEN_PROVIDER=
VOLCENGINE_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ANALYST_LIVE_PHOTO_MODEL=doubao-seedance-1-0-pro-fast-251015
# Optional for future Apple/iMessage delivery on macOS.
ANALYST_MAKELIVE_BINARY=makelive
FRED_API_KEY=
EIA_API_KEY=
IMF_API_KEY=
# IMF SDMX 3.0 API — https://api.imf.org (requires subscription key from https://portal.api.imf.org)

# International macro data sources (no API keys required)
# Eurostat JSON-stat API — https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data
# BIS SDMX-JSON API — https://data.bis.org/api/v2
# ECB SDMX API — https://data-api.ecb.europa.eu (no API key required)
# OECD SDMX API — https://sdmx.oecd.org (no API key required)
# World Bank API — https://api.worldbank.org/v2 (no API key required)

# Telegram bot token from @BotFather
ANALYST_TELEGRAM_TOKEN=your-telegram-bot-token-here

# Interactive Brokers Client Portal Gateway
ANALYST_IBKR_GATEWAY_URL=https://localhost:5000/v1/api
ANALYST_IBKR_ACCOUNT_ID=

# Longbridge (长桥) OpenAPI — https://open.longportapp.com
ANALYST_LONGBRIDGE_APP_KEY=
ANALYST_LONGBRIDGE_APP_SECRET=
ANALYST_LONGBRIDGE_ACCESS_TOKEN=

# Tiger Brokers (老虎证券) Open Platform — https://quant.itigerup.com
# Requires: pip install cryptography (for RSA signing)
ANALYST_TIGER_ID=
ANALYST_TIGER_PRIVATE_KEY=  # PEM file path or inline PEM content
ANALYST_TIGER_ACCOUNT=
