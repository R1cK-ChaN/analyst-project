# Analyst project local environment
# Copy to `.env` and fill values for this self-contained project.

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANALYST_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
ANALYST_TELEGRAM_OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
FRED_API_KEY=

# Telegram bot token from @BotFather
ANALYST_TELEGRAM_TOKEN=your-telegram-bot-token-here
